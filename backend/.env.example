PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/healthlink-clinic

# Auth (obligatoire en production — même valeur sur Render)
JWT_SECRET=changez_moi_en_production

# URLs (production)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Email (obligatoire sur Render pour les notifications)
ADMIN_EMAIL=admin@example.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
# Alias acceptés :
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Wave API Configuration
WAVE_API_KEY=your_wave_api_key_here
WAVE_BUSINESS_ID=your_wave_business_id_here

# Orange Money Configuration
ORANGE_MONEY_API_KEY=your_orange_money_api_key_here
ORANGE_MONEY_MERCHANT_ID=your_orange_money_merchant_id_here
